		{
			"src": "^/admin/settings/?$",
			"dest": "_render"
		},
		{
			"src": "^/admin/sheets/?$",
			"dest": "_render"
		},
		{
			"src": "^/admin/sponsor/add/?$",
			"dest": "_render"
		},
		{
			"src": "^/admin/sponsor/?$",
			"dest": "_render"
		},
		{
			"src": "^/admin/statistics/?$",
			"dest": "_render"
