		},
		{
			"src": "^/api/login/?$",
			"dest": "_render"
		},
		{
			"src": "^/api/register/?$",
			"dest": "_render"
		},
		{
			"src": "^/api/updateGallery/?$",
			"dest": "_render"
		},
		{
			"src": "^/api/updateParticipant/?$",
			"dest": "_render"
		},
		{
			"src": "^/api/updateSettings/?$",
			"dest": "_render"
