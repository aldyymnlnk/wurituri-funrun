		},
		{
			"src": "^/admin/faq/?$",
			"dest": "_render"
		},
		{
			"src": "^/admin/gallery/add/?$",
			"dest": "_render"
		},
		{
			"src": "^/admin/gallery/edit/([^/]+?)/?$",
			"dest": "_render"
		},
		{
			"src": "^/admin/gallery/?$",
			"dest": "_render"
		},
		{
			"src": "^/admin/login/?$",
			"dest": "_render"
