---
import AdminLayout from "../../../layouts/AdminLayout.astro";
import AdminSidebar from "../../../components/admin/AdminSidebar.astro";
import AdminNavbar from "../../../components/admin/AdminNavbar.astro";
---

<AdminLayout title="Tambah Sponsor">

<AdminSidebar />

<main class="admin-content">

<AdminNavbar />

<section class="table-card">

<h2>

Tambah Sponsor

</h2>

<form
action="/api/addSponsor"
method="POST"
>

<div class="form-group">

<label>

Nama Sponsor

</label>

<input
type="text"
name="name"
required
/>

</div>

<div class="form-group">

<label>

Logo (URL)

</label>

<input
type="text"
name="image"
required
/>

</div>

<div class="form-group">

<label>

Website

</label>

<input
type="text"
name="website"
/>

</div>

<button
class="btn btn-success"
type="submit"
>

💾 Simpan

</button>

<a
href="/admin/sponsor"
class="btn btn-warning"
>

⬅ Kembali

</a>

</form>

</section>

</main>

</AdminLayout>